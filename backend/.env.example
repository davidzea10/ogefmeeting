NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# En production (Render) : URL(s) COMPLÈTE(S) avec https://, séparées par des virgules
# Exemple :
# CORS_ORIGIN=https://ogefmeeting-frontend.vercel.app,http://localhost:5173
# Les previews Vercel (…-git-main-….vercel.app) sont aussi acceptées si une URL *.vercel.app est listée.
# (sans slash final)

# Supabase — URL du projet SANS /rest/v1/
# Exemple correct : https://xxxx.supabase.co
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Auth JWT — false = jamais bloquant (recommandé pour déploiement / démo)
# true = requireAuth, requireRoles et requirePermission refusent les requêtes sans token / droits
AUTH_ENFORCED=false

# Emails (optionnel) — Resend https://resend.com
# Sans RESEND_API_KEY : les mails sont écrits dans les logs du backend (mode dev)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Ogefmeeting <noreply@votredomaine.com>
