VITE_API_URL=http://localhost:4000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Pour le mode live (Realtime) : renseigner URL + anon key, et publier les tables
# reunions, points_ordre_jour, participants_reunion dans supabase_realtime.
# Sans config : fallback polling 8s côté client.

# true = routes app protégées (redirige vers /connexion si non authentifié)
# false = navigation libre (aligné AUTH_ENFORCED=false côté API)
VITE_AUTH_REQUIRED=false
